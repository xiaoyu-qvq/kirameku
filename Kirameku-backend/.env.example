# 数据库
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 应用密钥
SECRET_KEY=your-secret-key

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://your-domain.com

# GitHub OAuth（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 阿里云 OSS
OSS_ACCESS_KEY_ID=your-aliyun-access-key-id
OSS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_CUSTOM_DOMAIN=https://your-custom-domain.com
OSS_PREFIX=Boke/
